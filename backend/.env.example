# ===========================================
# FinanceFlow Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# For Supabase: Use Pooler URL here
DATABASE_URL=postgresql://user:password@localhost:5432/financeflow

# Direct database connection (for Prisma migrations)
# For Supabase: Use Direct connection URL
DIRECT_URL=postgresql://user:password@localhost:5432/financeflow

# JWT Configuration
# IMPORTANT: Generate a strong secret for production!
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_ISSUER=financeflow-api
JWT_AUDIENCE=financeflow-client

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
